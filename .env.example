# ─────────────────────────────────────────────────────────────
#  TechStop Trial Bot — environment variables
#  Copy this file to ".env" and fill in real values.
#  NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────

# ── Xtream UI reseller panel (admin login for Puppeteer) ──────
PANEL_URL=https://techstop.online:2096
PANEL_USERNAME=your-panel-username
PANEL_PASSWORD=your-panel-password

# Trial length and which bouquet to assign
TRIAL_DURATION_HOURS=24
DEFAULT_BOUQUET=all channels no adults

# ── Customer-facing streaming server ─────────────────────────
# IMPORTANT: this is NOT the admin panel (:2096). Xtream *clients*
# connect to the streaming port — usually :8080. The M3U URL and
# Xtream codes shown to the customer use THIS url, not PANEL_URL.
CLIENT_SERVER_URL=http://techstop.online:8080

# ── Gmail SMTP (Nodemailer) ──────────────────────────────────
# EMAIL_PASS must be a Gmail "App Password" (16 chars), NOT your
# normal password. Requires 2-Step Verification enabled:
# https://myaccount.google.com/apppasswords
EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your16charapppassword

# Where failure alerts are sent
ADMIN_EMAIL=mohammedmohid1010@gmail.com

# ── Admin dashboard ──────────────────────────────────────────
# Password the /admin/trials page must send to read the trial log.
ADMIN_DASHBOARD_PASSWORD=change-this-password

# ── Limits & networking ──────────────────────────────────────
# Max trial requests per IP per 24h (abuse protection)
RATE_LIMIT_PER_DAY=3
# Hard timeout for the whole Puppeteer flow (ms)
AUTOMATION_TIMEOUT_MS=30000
# Port (Railway/Render set this automatically — leave as-is)
PORT=8090
# Your website origin, e.g. https://techstopiptv.com (or * to allow all)
CORS_ORIGIN=*

# ── Firestore persistence (OPTIONAL but recommended) ─────────
# So the admin dashboard survives restarts. Paste the FULL JSON of
# a Firebase service-account key on ONE line (Firebase Console →
# Project settings → Service accounts → Generate new private key).
# Leave blank to fall back to in-memory storage.
FIREBASE_SERVICE_ACCOUNT_JSON=
